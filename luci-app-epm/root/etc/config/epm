config epm 'epm'
	option apdu_backend 'qmi'
	option http_backend 'curl'

	option qmi_device '/dev/cdc-wdm0'
	option qmi_sim_slot '1'

	option at_device '/dev/ttyUSB3'

	option mbim_device '/dev/cdc-wdm0'
	option mbim_proxy '0'

	option reboot_method 'qmi'
	option reboot_at_command 'AT+CFUN=1,1'
	option reboot_at_device '/dev/ttyUSB3'
	option reboot_qmi_device '/dev/cdc-wdm0'
	option reboot_qmi_slot '1'
	option reboot_mbim_device '/dev/cdc-wdm0'
	option reboot_custom_command 'echo "Custom reboot command here"'

	option json_output '0'
