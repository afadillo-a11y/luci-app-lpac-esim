{
  "luci-app-epm-qmi": {
    "description": "Grant access to eSIM Profile Manager QMI/AT frontend for lpac 2.3.0",
    "read": {
      "uci": [ "epm" ],
      "file": {
        "/usr/bin/lpac": [ "exec" ],
        "/usr/sbin/qmicli": [ "exec" ],
        "/sbin/logread": [ "exec" ]
      }
    },
    "write": {
      "uci": [ "epm" ]
    }
  }
}
